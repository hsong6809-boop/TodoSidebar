<Window x:Class="TodoSidebar.FullWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoSidebar.ViewModels"
        xmlns:helpers="clr-namespace:TodoSidebar.Helpers"
        Title="Todo Sidebar - 完整模式"
        Width="450"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- 优先级选择器样式 -->
        <Style x:Key="PriorityComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource GlassBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部栏 -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource GlassLightBrush}"
                    Padding="20,16"
                    CornerRadius="12,12,0,0"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource BorderBrush}">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Todo 完整模式" 
                                   FontSize="20" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="📊" 
                                Click="StatisticsButton_Click"
                                Style="{StaticResource PrimaryButton}"
                                Padding="8,6"
                                Margin="0,0,8,0"
                                ToolTip="数据统计"/>
                        <Button Content="⚙️" 
                                Click="SettingsButton_Click"
                                Style="{StaticResource PrimaryButton}"
                                Padding="8,6"
                                Margin="0,0,8,0"
                                ToolTip="设置"/>
                        <Button Content="🚪" 
                                Click="LogoutButton_Click"
                                Style="{StaticResource PrimaryButton}"
                                Padding="8,6"
                                Margin="0,0,8,0"
                                ToolTip="退出登录"/>
                        <Button Content="◀ 收起" 
                                Click="CollapseToSidebar_Click"
                                Style="{StaticResource PrimaryButton}"
                                Padding="12,8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tab 切换 -->
            <Border Grid.Row="1" 
                    Background="{DynamicResource GlassBrush}"
                    Padding="12,8"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <RadioButton x:Name="TabDaily" Content="每日" 
                                 Style="{StaticResource TabRadioButton}"
                                 IsChecked="True"
                                 Checked="Tab_Checked"/>
                    <RadioButton x:Name="TabDeadline" Content="截止" 
                                 Style="{StaticResource TabRadioButton}"
                                 Checked="Tab_Checked"/>
                    <RadioButton x:Name="TabTemplate" Content="模板" 
                                 Style="{StaticResource TabRadioButton}"
                                 Checked="Tab_Checked"/>
                    <RadioButton x:Name="TabHistory" Content="历史" 
                                 Style="{StaticResource TabRadioButton}"
                                 Checked="Tab_Checked"/>
                    <RadioButton x:Name="TabStatistics" Content="📊" 
                                 Style="{StaticResource TabRadioButton}"
                                 Checked="Tab_Checked"/>
                </StackPanel>
            </Border>

            <!-- 内容区域 -->
            <Grid Grid.Row="2" Background="Transparent">
                <!-- 每日任务 -->
                <DockPanel x:Name="DailyPanel" 
                           Visibility="{Binding IsChecked, ElementName=TabDaily, Converter={StaticResource BoolToVis}}"
                           Margin="16,12">
                    <!-- 计数器 -->
                    <Border DockPanel.Dock="Top" 
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="今日任务" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="10"
                                    Padding="8,4"
                                    Margin="8,0,0,0">
                                <TextBlock Text="{Binding DailyTasksCount}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <ListBox ItemsSource="{Binding DailyTasks}"
                             Style="{StaticResource GlassListBox}"
                             ItemTemplate="{StaticResource TaskCardTemplate}"
                             x:Name="DailyTasksListBox"
                             AllowDrop="True"
                             Drop="TaskListBox_Drop"
                             DragOver="TaskListBox_DragOver"
                             PreviewMouseLeftButtonDown="TaskListBox_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="TaskListBox_PreviewMouseMove"
                             MouseDoubleClick="TaskListBox_MouseDoubleClick"/>
                </DockPanel>

                <!-- 截止任务 -->
                <DockPanel x:Name="DeadlinePanel" 
                           Visibility="{Binding IsChecked, ElementName=TabDeadline, Converter={StaticResource BoolToVis}}"
                           Margin="16,12">
                    <!-- 计数器 -->
                    <Border DockPanel.Dock="Top" 
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="截止任务" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <Border Background="{DynamicResource DangerBrush}"
                                    CornerRadius="10"
                                    Padding="8,4"
                                    Margin="8,0,0,0">
                                <TextBlock Text="{Binding DeadlineTasksCount}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <ListBox ItemsSource="{Binding DeadlineTasks}"
                             Style="{StaticResource GlassListBox}"
                             ItemTemplate="{StaticResource DeadlineTaskCardTemplate}"
                             x:Name="DeadlineTasksListBox"
                             AllowDrop="True"
                             Drop="TaskListBox_Drop"
                             DragOver="TaskListBox_DragOver"
                             PreviewMouseLeftButtonDown="TaskListBox_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="TaskListBox_PreviewMouseMove"
                             MouseDoubleClick="TaskListBox_MouseDoubleClick"/>
                </DockPanel>

                <!-- 模板 -->
                <DockPanel x:Name="TemplatePanel" 
                           Visibility="{Binding IsChecked, ElementName=TabTemplate, Converter={StaticResource BoolToVis}}"
                           Margin="16,12">
                    <Border DockPanel.Dock="Top" 
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 任务模板" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="10"
                                    Padding="8,4"
                                    Margin="8,0,0,0">
                                <TextBlock Text="{Binding Templates.Count}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <ListBox ItemsSource="{Binding Templates}"
                             Style="{StaticResource GlassListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}"
                                        CornerRadius="10"
                                        Padding="16,12"
                                        Margin="0,4"
                                        Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Icon}"
                                                   FontSize="24"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="15"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Content="使用"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding DataContext.ApplyTemplateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="12,6"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- 历史记录 -->
                <DockPanel x:Name="HistoryPanel" 
                           Visibility="{Binding IsChecked, ElementName=TabHistory, Converter={StaticResource BoolToVis}}"
                           Margin="16,12">
                    <!-- 计数器 -->
                    <Border DockPanel.Dock="Top" 
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="历史记录" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <Border Background="{DynamicResource TextSecondaryBrush}"
                                    CornerRadius="10"
                                    Padding="8,4"
                                    Margin="8,0,0,0">
                                <TextBlock Text="{Binding HistoryTasksCount}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <ListBox ItemsSource="{Binding HistoryTasks}"
                             Style="{StaticResource GlassListBox}"
                             ItemTemplate="{StaticResource HistoryTaskCardTemplate}"/>
                </DockPanel>

                                <!-- 统计 -->
                <ScrollViewer x:Name="StatisticsPanel" 
                              Visibility="{Binding IsChecked, ElementName=TabStatistics, Converter={StaticResource BoolToVis}}"
                              Margin="16,12">
                    <StackPanel>
                        <!-- 总体概览 -->
                        <Border Background="{DynamicResource CardBrush}"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📈 总体概览" 
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding StatisticsViewModel.TotalTasks}" 
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="总任务" 
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding StatisticsViewModel.CompletedTasks}" 
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="已完成" 
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding StatisticsViewModel.OverdueTasks}" 
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="已过期" 
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- 今日统计 -->
                        <Border Background="{DynamicResource CardBrush}"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📅 今日统计" 
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding StatisticsViewModel.TodayTotal}" 
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="今日任务" 
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding StatisticsViewModel.TodayCompleted}" 
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="已完成" 
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- 连续完成天数 -->
                        <Border Background="{DynamicResource CardBrush}"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,0,0,12">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding StatisticsViewModel.StreakDays}" 
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource WarningBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="🔥 连续完成天数" 
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- 底部添加栏 -->
            <Border Grid.Row="3" 
                    Background="{DynamicResource GlassLightBrush}"
                    Padding="16,12"
                    CornerRadius="0,0,12,12"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel>
                    <!-- 输入框和添加按钮 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TaskInput"
                                 Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource GlassTextBox}"/>
                        <Button Grid.Column="1"
                                Content="+ 添加"
                                Click="AddTaskButton_Click"
                                Style="{StaticResource PrimaryButton}"
                                Margin="10,0,0,0"/>
                    </Grid>
                    
                    <!-- 优先级选择 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="优先级:" 
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton Content="高" 
                                         Tag="High"
                                         Foreground="{StaticResource PriorityHighBrush}"
                                         Margin="0,0,15,0"
                                         Checked="Priority_Checked"/>
                            <RadioButton Content="中" 
                                         Tag="Medium"
                                         Foreground="{StaticResource PriorityMediumBrush}"
                                         IsChecked="True"
                                         Margin="0,0,15,0"
                                         Checked="Priority_Checked"/>
                            <RadioButton Content="低" 
                                         Tag="Low"
                                         Foreground="{StaticResource PriorityLowBrush}"
                                         Checked="Priority_Checked"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- 截止日期选择（仅截止任务Tab显示） -->
                    <DatePicker x:Name="DeadlinePicker"
                                SelectedDate="{Binding NewTaskDeadline}"
                                Visibility="{Binding IsChecked, ElementName=TabDeadline, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,10"/>

                    


                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
