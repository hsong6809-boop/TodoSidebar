<Window x:Class="TodoSidebar.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录 - TodoSidebar"
        Width="360"
        Height="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#5B5FE9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4FD4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5B5FE9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="White"
            CornerRadius="16"
            Margin="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    Background="#F8F9FA"
                    CornerRadius="16,16,0,0"
                    Padding="20,16"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✓ TodoSidebar"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#333333"/>
                        <TextBlock Text="同步你的待办事项"
                                   FontSize="12"
                                   Foreground="#999999"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 登录表单 -->
            <ScrollViewer Grid.Row="1"
                          Padding="24,20"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 邮箱 -->
                    <TextBlock Text="邮箱"
                               FontSize="12"
                               Foreground="#666666"
                               Margin="0,0,0,6"/>
                    <Border Background="#F5F5F5"
                            CornerRadius="8"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Margin="0,0,0,16">
                        <TextBox x:Name="EmailTextBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="12,10"
                                 FontSize="14"
                                 Foreground="#333333"
                                 VerticalContentAlignment="Center"/>
                    </Border>
                    
                    <!-- 密码 -->
                    <TextBlock Text="密码"
                               FontSize="12"
                               Foreground="#666666"
                               Margin="0,0,0,6"/>
                    <Border Background="#F5F5F5"
                            CornerRadius="8"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Margin="0,0,0,8">
                        <PasswordBox x:Name="PasswordBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="12,10"
                                     FontSize="14"
                                     Foreground="#333333"
                                     VerticalContentAlignment="Center"/>
                    </Border>
                    
                    <!-- 记住我 + 忘记密码 -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="RememberMeCheckBox"
                                  Content="记住我"
                                  FontSize="12"
                                  Foreground="#666666"
                                  VerticalAlignment="Center"/>
                        <Button Content="忘记密码？"
                                Style="{StaticResource LinkButton}"
                                Grid.Column="1"
                                Click="ForgotPassword_Click"/>
                    </Grid>
                    
                    <!-- 错误提示 -->
                    <TextBlock x:Name="ErrorText"
                               Foreground="#E74C3C"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,16"/>
                    
                    <!-- 登录按钮 -->
                    <Button x:Name="LoginButton"
                            Content="登录"
                            Style="{StaticResource LoginButton}"
                            Click="LoginButton_Click"
                            IsDefault="True"/>
                    
                    <!-- 分隔线 -->
                    <Grid Margin="0,20,0,20">
                        <Border Height="1"
                                Background="#E0E0E0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="或"
                                   Background="White"
                                   Padding="12,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#999999"
                                   FontSize="12"/>
                    </Grid>
                    
                    <!-- 注册链接 -->
                    <StackPanel HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <TextBlock Text="没有账号？"
                                   Foreground="#666666"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Button Content="立即注册"
                                Style="{StaticResource LinkButton}"
                                Click="RegisterButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            
            <!-- 底部 -->
            <Border Grid.Row="2"
                    Background="#F8F9FA"
                    CornerRadius="0,0,16,16"
                    Padding="20,12">
                <TextBlock Text="你的数据将通过加密传输和存储"
                           FontSize="10"
                           Foreground="#999999"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
