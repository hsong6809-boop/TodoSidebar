<Window x:Class="TodoSidebar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoSidebar.ViewModels"
        xmlns:mahapps="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:tabler="http://schemas.iconpacks.tabler"
        Title="Todo Sidebar"
        Width="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Left="0"
        Top="0"
        Height="800"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- 侧边栏按钮样式 -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
                <!-- 主面板 -->
                <Border x:Name="MainPanel"
                        Background="{DynamicResource GlassBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="0,16,16,0"
                        Margin="0"
                        Width="320">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
                    </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 顶部栏（可拖动） -->
                <Border Grid.Row="0"
                        Background="{DynamicResource GlassLightBrush}"
                        Padding="16,14"
                        CornerRadius="0,16,0,0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="8"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,10,0">
                                <TextBlock Text="✓"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="DateTimeText"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="当前任务"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="共 "/>
                                    <Run Text="{Binding CurrentTasksCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text=" 项待办"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource MahappsIconButton}"
                                    Click="SettingsButton_Click"
                                    ToolTip="设置">
                                <TextBlock Text="⚙" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource MahappsIconButton}"
                                    Click="ExpandFullMode_Click"
                                    ToolTip="展开主窗口"
                                    Margin="4,0,0,0">
                                <TextBlock Text="⤢" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource MahappsIconButton}"
                                    Click="CollapseButton_Click"
                                    ToolTip="收起">
                                <TextBlock Text="◀" FontSize="16"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 快速添加区域 -->
                <Border Grid.Row="1"
                        Padding="12,8"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource CardBrush}"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <TextBox x:Name="QuickAddInput"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="10,8"
                                         FontSize="13"
                                         Foreground="{DynamicResource TextBrush}"
                                         VerticalContentAlignment="Center"
                                         KeyDown="QuickAddInput_KeyDown"/>
                            </Border>
                            <Button Grid.Column="1"
                                    Content="+"
                                    Style="{StaticResource IconButton}"
                                    Click="QuickAddButton_Click"
                                    Width="32"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    ToolTip="快速添加任务"/>
                        </Grid>
                        <!-- 截止日期选择 -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker x:Name="QuickDeadlinePicker"
                                        FontSize="11"
                                        SelectedDateFormat="Short"
                                        Height="24"
                                        VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="💡 不选日期=每日任务"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 当前任务列表 -->
                <ListBox Grid.Row="2"
                         x:Name="TaskListBox"
                         ItemsSource="{Binding CurrentTasks}"
                         Style="{StaticResource GlassListBox}"
                         Margin="8,8"
                         AllowDrop="True"
                         Drop="TaskListBox_Drop"
                         DragOver="TaskListBox_DragOver"
                         PreviewMouseLeftButtonDown="TaskListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="TaskListBox_PreviewMouseMove"
                         Visibility="{Binding IsSearchMode, Converter={StaticResource InvertedBoolToVis}}"
                         MouseDoubleClick="TaskListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TaskCard"
                                    CornerRadius="14"
                                    Padding="16,14"
                                    Margin="0,2"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="TaskCard_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Style.Triggers>
                                            <!-- 项目制任务：左边框蓝色，带底色 -->
                                            <DataTrigger Binding="{Binding Type}" Value="1">
                                                <Setter Property="Background" Value="{DynamicResource DeadlineCardBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                                <Setter Property="BorderThickness" Value="1,1,3,1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 任务类型图标 -->
                                    <Border Grid.Column="0"
                                            CornerRadius="12"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,14,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="1">
                                                        <Setter Property="Background" Value="{DynamicResource WarningLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    <TextBlock x:Name="TypeIcon"
                                               Text="☀"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentBrush}">
                                    </TextBlock>
                                    </Border>

                                    <!-- 任务内容 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="14"
                                                   FontWeight="Normal"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- 项目制任务显示截止日期和倒计时 -->
                                        <StackPanel x:Name="DeadlineRow"
                                                    Orientation="Horizontal"
                                                    Margin="0,3,0,0"
                                                    Visibility="Collapsed">
                                <TextBlock Text="⏰" FontSize="11"/>
                                            <TextBlock Text="{Binding Deadline, StringFormat='{}{0:MM/dd}'}"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text=" · "
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding DeadlineUrgency}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource WarningBrush}"/>
                                        </StackPanel>
                                        <!-- 每日任务显示标签 -->
                                        <StackPanel x:Name="DailyRow"
                                                    Orientation="Horizontal"
                                                    Margin="0,6,0,0">
                                            <Border Background="{DynamicResource AccentSubtleBrush}"
                                                    CornerRadius="6"
                                                    Padding="8,3">
                                                <TextBlock Text="每日"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <!-- 子任务进度（点击可展开） -->
                                        <StackPanel x:Name="SubTaskRow"
                                                    Orientation="Horizontal"
                                                    Margin="0,3,0,0"
                                                    Visibility="Collapsed">
                                <TextBlock Text="📋" FontSize="11"/>
                                            <TextBlock Text="{Binding SubTasksProgressText}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text=" · 点击展开"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <!-- 展开区域：子任务详情 -->
                                        <StackPanel x:Name="ExpandArea"
                                                    Visibility="Collapsed"
                                                    Margin="0,8,0,0">
                                            <!-- 子任务列表 -->
                                            <ItemsControl x:Name="SubTasksList"
                                                          ItemsSource="{Binding SubTasksList}"
                                                          Margin="0,0,0,6">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                                            <CheckBox IsChecked="{Binding IsCompleted}"
                                                                      Click="SubTaskCheckBox_Click"
                                                                      Width="16" Height="16"
                                                                      Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="11"
                                                                       Foreground="{Binding IsCompleted, Converter={StaticResource SubTaskForeground}}"
                                                                       TextDecorations="{Binding IsCompleted, Converter={StaticResource SubTaskStrike}}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- 添加子任务输入框 -->
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#10000000"
                                                        CornerRadius="6"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <TextBox x:Name="SubTaskInput"
                                                             Text="{Binding DataContext.NewSubTaskTitle, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Padding="8,4"
                                                             FontSize="11"
                                                             Foreground="{DynamicResource TextBrush}"
                                                             VerticalContentAlignment="Center"
                                                             Tag="{Binding}"
                                                             KeyDown="SubTaskInput_KeyDown"/>
                                                </Border>
                                                <Button Grid.Column="1"
                                                        Content="+"
                                                        Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.AddSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Width="24"
                                                        Height="24"
                                                        Margin="4,0,0,0"
                                                        FontSize="12"
                                                        ToolTip="添加子任务"/>
                                            </Grid>
                                            <!-- 展开/收起提示 -->
                                            <TextBlock Text="点击收起 ▴"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="✓"
                                                Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource IconButton}"
                                                Width="32"
                                                Height="32"
                                                Foreground="{DynamicResource SuccessBrush}"
                                                FontWeight="Bold"
                                                Margin="0,0,6,0"/>
                                        <Button Content="×"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource IconButton}"
                                                Width="32"
                                                Height="32"
                                                Foreground="{DynamicResource TextTertiaryBrush}"
                                                FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- 项目制任务显示截止日期行 -->
                                <DataTrigger Binding="{Binding Type}" Value="1">
                                    <Setter TargetName="DeadlineRow" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="DailyRow" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="TypeIcon" Property="Text" Value="🎯"/>
                                    <Setter TargetName="TypeIcon" Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                </DataTrigger>
                                <!-- 有子任务时显示进度 -->
                                <DataTrigger Binding="{Binding HasSubTasks}" Value="True">
                                    <Setter TargetName="SubTaskRow" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 今日已完成任务 -->
                <Border Grid.Row="3"
                        Padding="12,8"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Visibility="{Binding TodayCompletedTasksCount, Converter={StaticResource ZeroToVis}}">
                    <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <mahapps:PackIconMaterial Kind="CheckCircle" Foreground="{DynamicResource SuccessBrush}" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="今日已完成"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="4,0,0,0"/>
                            <Border Background="{DynamicResource SuccessBrush}"
                                    CornerRadius="8"
                                    Padding="6,2"
                                    Margin="6,0,0,0">
                                <TextBlock Text="{Binding TodayCompletedTasksCount}"
                                           Foreground="White"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding TodayCompletedTasks}"
                                 Style="{StaticResource GlassListBox}"
                                 MaxHeight="150"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                         <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontSize="14" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextDecorations="Strikethrough"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- 底部操作栏 -->
                <Border Grid.Row="4"
                        Background="{DynamicResource GlassLightBrush}"
                        Padding="16,12"
                        CornerRadius="0,0,16,16"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource MahappsIconButton}"
                                Click="StatisticsButton_Click"
                                HorizontalAlignment="Left">
                            <TextBlock Text="📊" FontSize="16"/>
                        </Button>
                        <Button Style="{StaticResource MahappsIconButton}"
                                Command="{Binding SyncViewModel.UploadCommand}"
                                ToolTip="上传到云端"
                                Grid.Column="1">
                            <TextBlock Text="⬆" FontSize="16"/>
                        </Button>
                        <Button Style="{StaticResource MahappsIconButton}"
                                Command="{Binding SyncViewModel.DownloadCommand}"
                                ToolTip="从云端下载"
                                Grid.Column="2">
                            <TextBlock Text="⬇" FontSize="16"/>
                        </Button>
                        
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- 触发条（鼠标悬停时显示主面板） -->
        <Border x:Name="TriggerStrip"
                Width="3"
                HorizontalAlignment="Left"
                Cursor="Hand">
            <Border.Background>
                <SolidColorBrush Color="#4F6AFF"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#4F6AFF" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
        </Border>
    </Grid>
</Window>
