<Window x:Class="TodoSidebar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoSidebar.ViewModels"
        Title="Todo Sidebar"
        Width="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Left="0"
        Top="0"
        Height="800"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- 侧边栏按钮样式 -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 图标按钮样式 -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 主面板 -->
        <Border x:Name="MainPanel"
                Background="{DynamicResource GlassBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                CornerRadius="0,16,16,0"
                Margin="0"
                Width="320">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.15"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 顶部栏（可拖动） -->
                <Border Grid.Row="0"
                        Background="{DynamicResource GlassLightBrush}"
                        Padding="16,14"
                        CornerRadius="0,16,0,0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="8"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,10,0">
                                <TextBlock Text="✓"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="当前任务"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           x:Name="TaskCountText">
                                    <Run Text="共 "/>
                                    <Run Text="{Binding CurrentTasksCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text=" 项待办"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="🔍"
                                    Style="{StaticResource IconButton}"
                                    Click="SearchButton_Click"
                                    ToolTip="搜索"
                                    Width="28"
                                    Height="28"/>
                            <Button Content="⚙"
                                    Style="{StaticResource IconButton}"
                                    Click="SettingsButton_Click"
                                    ToolTip="设置"
                                    Margin="4,0,0,0"/>
                            <Button Content="🚪"
                                    Style="{StaticResource IconButton}"
                                    Click="LogoutButton_Click"
                                    ToolTip="退出登录"
                                    Margin="4,0,0,0"/>
                            <Button Content="⤢"
                                    Style="{StaticResource IconButton}"
                                    Click="ExpandFullMode_Click"
                                    ToolTip="展开完整模式"
                                    Margin="4,0,0,0"/>
                            <Button Content="◀"
                                    Style="{StaticResource IconButton}"
                                    Click="CollapseButton_Click"
                                    ToolTip="收起"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 快速添加区域 -->
                <Border Grid.Row="1"
                        Padding="12,8"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource CardBrush}"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <TextBox x:Name="QuickAddInput"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="10,8"
                                         FontSize="13"
                                         Foreground="{DynamicResource TextBrush}"
                                         VerticalContentAlignment="Center"
                                         KeyDown="QuickAddInput_KeyDown"/>
                            </Border>
                            <Button Grid.Column="1"
                                    Content="+"
                                    Style="{StaticResource IconButton}"
                                    Click="QuickAddButton_Click"
                                    Width="32"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    ToolTip="快速添加任务"/>
                        </Grid>
                        <!-- 截止日期选择 -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker x:Name="QuickDeadlinePicker"
                                        FontSize="11"
                                        SelectedDateFormat="Short"
                                        Height="24"
                                        VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="💡 不选日期=每日任务"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 搜索框 -->
                <Border Grid.Row="2"
                        Padding="8,4"
                        Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource CardBrush}"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <TextBox x:Name="SearchInput"
                                     Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="10,8"
                                     FontSize="13"
                                     Foreground="{DynamicResource TextBrush}"
                                     VerticalContentAlignment="Center"
                                     KeyDown="SearchInput_KeyDown"/>
                        </Border>
                        <Button Grid.Column="1"
                                Content="✕"
                                Style="{StaticResource IconButton}"
                                Command="{Binding ClearSearchCommand}"
                                Width="28"
                                Height="28"
                                Margin="4,0,0,0"
                                ToolTip="清除搜索"/>
                    </Grid>
                </Border>

                <!-- 搜索结果列表 -->
                <ListBox Grid.Row="3"
                         x:Name="SearchResultsListBox"
                         ItemsSource="{Binding SearchResults}"
                         Style="{StaticResource GlassListBox}"
                         Margin="8,8"
                         Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVis}}"
                         MouseDoubleClick="TaskListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBrush}"
                                    CornerRadius="10"
                                    Padding="12,10"
                                    Margin="0,2"
                                    BorderThickness="0,0,3,0"
                                    BorderBrush="{Binding TypeColor}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{Binding PriorityColor}"
                                            CornerRadius="4"
                                            Width="4"
                                            Height="24"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="13"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Type, StringFormat='{}{0}'}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 当前任务列表 -->
                <ListBox Grid.Row="3"
                         x:Name="TaskListBox"
                         ItemsSource="{Binding CurrentTasks}"
                         Style="{StaticResource GlassListBox}"
                         Margin="8,8"
                         AllowDrop="True"
                         Drop="TaskListBox_Drop"
                         DragOver="TaskListBox_DragOver"
                         PreviewMouseLeftButtonDown="TaskListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="TaskListBox_PreviewMouseMove"
                         Visibility="{Binding IsSearchMode, Converter={StaticResource InvertedBoolToVis}}"
                         MouseDoubleClick="TaskListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TaskCard"
                                    CornerRadius="10"
                                    Padding="12,10"
                                    Margin="0,3"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="TaskCard_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                        <Style.Triggers>
                                            <!-- 项目制任务：左边框蓝色，带底色 -->
                                            <DataTrigger Binding="{Binding Type}" Value="1">
                                                <Setter Property="Background" Value="{DynamicResource DeadlineCardBrush}"/>
                                                <Setter Property="BorderThickness" Value="0,0,3,0"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 任务类型图标 -->
                                    <Border Grid.Column="0"
                                            CornerRadius="14"
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="1">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="📌"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="-30"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Border>

                                    <!-- 任务内容 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- 项目制任务显示截止日期和倒计时 -->
                                        <StackPanel x:Name="DeadlineRow"
                                                    Orientation="Horizontal"
                                                    Margin="0,3,0,0"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="⏰ "
                                                       FontSize="10"/>
                                            <TextBlock Text="{Binding Deadline, StringFormat='{}{0:MM/dd}'}"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text=" · "
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding DeadlineUrgency}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource WarningBrush}"/>
                                        </StackPanel>
                                        <!-- 每日任务显示标签 -->
                                        <StackPanel x:Name="DailyRow"
                                                    Orientation="Horizontal"
                                                    Margin="0,3,0,0">
                                            <Border Background="{DynamicResource AccentBrush}"
                                                    CornerRadius="4"
                                                    Padding="6,2">
                                                <TextBlock Text="每日"
                                                           FontSize="9"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <!-- 子任务进度（点击可展开） -->
                                        <StackPanel x:Name="SubTaskRow"
                                                    Orientation="Horizontal"
                                                    Margin="0,3,0,0"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="📋 "
                                                       FontSize="10"/>
                                            <TextBlock Text="{Binding SubTasksProgressText}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text=" · 点击展开"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <!-- 展开区域：子任务详情 -->
                                        <StackPanel x:Name="ExpandArea"
                                                    Visibility="Collapsed"
                                                    Margin="0,8,0,0">
                                            <!-- 子任务列表 -->
                                            <ItemsControl x:Name="SubTasksList"
                                                          ItemsSource="{Binding SubTasksList}"
                                                          Margin="0,0,0,6">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                                            <CheckBox IsChecked="{Binding IsCompleted}"
                                                                      Click="SubTaskCheckBox_Click"
                                                                      Width="16" Height="16"
                                                                      Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="11"
                                                                       Foreground="{Binding IsCompleted, Converter={StaticResource SubTaskForeground}}"
                                                                       TextDecorations="{Binding IsCompleted, Converter={StaticResource SubTaskStrike}}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- 添加子任务输入框 -->
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#10000000"
                                                        CornerRadius="6"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <TextBox x:Name="SubTaskInput"
                                                             Text="{Binding DataContext.NewSubTaskTitle, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Padding="8,4"
                                                             FontSize="11"
                                                             Foreground="{DynamicResource TextBrush}"
                                                             VerticalContentAlignment="Center"
                                                             Tag="{Binding}"
                                                             KeyDown="SubTaskInput_KeyDown"/>
                                                </Border>
                                                <Button Grid.Column="1"
                                                        Content="+"
                                                        Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.AddSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Width="24"
                                                        Height="24"
                                                        Margin="4,0,0,0"
                                                        FontSize="12"
                                                        ToolTip="添加子任务"/>
                                            </Grid>
                                            <!-- 展开/收起提示 -->
                                            <TextBlock Text="点击收起 ▴"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="✓"
                                                Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource IconButton}"
                                                Width="26"
                                                Height="26"
                                                Foreground="{DynamicResource SuccessBrush}"
                                                FontWeight="Bold"
                                                Margin="0,0,4,0"/>
                                        <Button Content="×"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource IconButton}"
                                                Width="26"
                                                Height="26"
                                                Foreground="{DynamicResource DangerBrush}"
                                                FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- 项目制任务显示截止日期行 -->
                                <DataTrigger Binding="{Binding Type}" Value="1">
                                    <Setter TargetName="DeadlineRow" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="DailyRow" Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <!-- 有子任务时显示进度 -->
                                <DataTrigger Binding="{Binding HasSubTasks}" Value="True">
                                    <Setter TargetName="SubTaskRow" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 底部操作栏 -->
                <Border Grid.Row="4"
                        Background="{DynamicResource GlassLightBrush}"
                        Padding="12,10"
                        CornerRadius="0,0,16,16"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="📊 统计"
                                Style="{StaticResource SidebarButton}"
                                Click="StatisticsButton_Click"
                                HorizontalAlignment="Left"/>
                        
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- 触发条（鼠标悬停时显示主面板） -->
        <Border x:Name="TriggerStrip"
                Width="6"
                HorizontalAlignment="Left"
                Cursor="Hand">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
            </Border.Effect>
        </Border>
    </Grid>
</Window>
