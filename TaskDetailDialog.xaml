<Window x:Class="TodoSidebar.TaskDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务详情"
        Width="400"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">
    
    <Border Background="{DynamicResource GlassBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0"
                    Background="{DynamicResource GlassLightBrush}"
                    Padding="16,14"
                    CornerRadius="12,12,0,0"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="📋 任务详情"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Click="CancelButton_Click"
                            Style="{StaticResource IconButton}"
                            Width="24"
                            Height="24"
                            FontSize="12"
                            ToolTip="关闭"/>
                </Grid>
            </Border>

            <!-- 编辑区域 -->
            <Border Grid.Row="1"
                    Padding="16,12"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel>
                    <!-- 标题 -->
                    <TextBox x:Name="TitleInput"
                             Style="{StaticResource GlassTextBox}"
                             Margin="0,0,0,8"
                             FontSize="14"/>
                    
                    <!-- 优先级和截止日期 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 优先级 -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="优先级" 
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="PriorityHigh" Content="高" 
                                             Tag="High"
                                             Foreground="{DynamicResource PriorityHighBrush}"
                                             Margin="0,0,10,0"
                                             Checked="Priority_Checked"/>
                                <RadioButton x:Name="PriorityMedium" Content="中" 
                                             Tag="Medium"
                                             Foreground="{DynamicResource PriorityMediumBrush}"
                                             Margin="0,0,10,0"
                                             Checked="Priority_Checked"/>
                                <RadioButton x:Name="PriorityLow" Content="低" 
                                             Tag="Low"
                                             Foreground="{DynamicResource PriorityLowBrush}"
                                             Checked="Priority_Checked"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 截止日期 -->
                        <StackPanel Grid.Column="1" x:Name="DeadlinePanel">
                            <TextBlock Text="截止日期" 
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <DatePicker x:Name="DeadlinePicker"
                                        FontSize="12"
                                        SelectedDateFormat="Short"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 子任务区域 -->
            <Border Grid.Row="2"
                    Margin="16,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 子任务标题 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="📋 子任务"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ProgressText"
                                   Text="0/0"
                                   FontSize="12"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- 子任务列表 -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SubTasksItemsControl"
                                      AlternationCount="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBrush}"
                                            CornerRadius="8"
                                            Padding="12,8"
                                            Margin="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsCompleted}"
                                                      Click="SubTaskCheckBox_Click"
                                                      Width="18"
                                                      Height="18"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       FontSize="13"
                                                       Foreground="{Binding IsCompleted, Converter={StaticResource SubTaskForeground}}"
                                                       TextDecorations="{Binding IsCompleted, Converter={StaticResource SubTaskStrike}}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                            <Button Grid.Column="2"
                                                    Content="×"
                                                    Tag="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                                    Click="DeleteSubTaskButton_Click"
                                                    Style="{StaticResource IconButton}"
                                                    Width="20"
                                                    Height="20"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource DangerBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="4,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 底部操作栏 -->
            <Border Grid.Row="3"
                    Background="{DynamicResource GlassLightBrush}"
                    Padding="16,12"
                    CornerRadius="0,0,12,12"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource BorderBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- 添加子任务输入框 -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewSubTaskInput"
                                 Style="{StaticResource GlassTextBox}"
                                 KeyDown="NewSubTaskInput_KeyDown"/>
                        <Button Grid.Column="1"
                                Content="+ 添加"
                                Click="AddSubTaskButton_Click"
                                Style="{StaticResource PrimaryButton}"
                                Margin="8,0,0,0"/>
                    </Grid>
                    <!-- 保存按钮 -->
                    <Button Grid.Row="1"
                            Content="✓ 保存"
                            Click="SaveButton_Click"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Padding="12,8"
                            FontSize="14"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
