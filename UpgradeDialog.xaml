<Window x:Class="TodoSidebar.UpgradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="升级到 Pro"
        Width="420"
        Height="540"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">
    
    <Border Background="{DynamicResource GlassBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0"
                    Background="{DynamicResource GlassLightBrush}"
                    Padding="16,14"
                    CornerRadius="12,12,0,0"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⭐" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="升级到 Pro"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="CloseButton_Click"
                            Style="{DynamicResource CloseButtonStyle}"
                            FontSize="14"/>
                </Grid>
            </Border>

            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="1" Padding="20,16" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 当前状态 -->
                    <Border Background="{DynamicResource CardBrush}"
                            CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="当前版本" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="CurrentTierText"
                                       Text="Free 版"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock x:Name="TrialStatusText"
                                       Text=""
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Pro 功能列表 -->
                    <TextBlock Text="Pro 功能" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>

                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="☁️" Width="24"/>
                            <TextBlock Text="云同步 — 多设备实时同步，离线支持"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="📊" Width="24"/>
                            <TextBlock Text="数据统计 — 完成率、连续天数、趋势图表"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="🔍" Width="24"/>
                            <TextBlock Text="高级搜索 — 全文搜索、筛选器、保存搜索条件"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="🏷️" Width="24"/>
                            <TextBlock Text="标签系统 — 自定义标签、按标签筛选"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="🎨" Width="24"/>
                            <TextBlock Text="自定义主题 — 颜色、字体、透明度"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="📄" Width="24"/>
                            <TextBlock Text="无限模板 + CSV/Markdown 导出"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 定价 -->
                    <Border Background="{DynamicResource CardBrush}"
                            CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="¥9.9/月" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="或 ¥79/年（省 34%）" FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="比 Todoist 便宜 70%，比 TickTick 便宜 55%"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 提示文字 -->
                    <TextBlock x:Name="StatusText"
                               Text=""
                               FontSize="12"
                               Foreground="{DynamicResource WarningBrush}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮区 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource GlassLightBrush}"
                    Padding="16,12"
                    CornerRadius="0,0,12,12"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel>
                    <!-- 开始试用 -->
                    <Button x:Name="TrialButton"
                            Content="🎁 开始 14 天免费试用"
                            Click="TrialButton_Click"
                            Style="{DynamicResource PrimaryButton}"
                            Padding="16,10"
                            FontSize="14"
                            Margin="0,0,0,8"/>

                    <!-- 购买 Pro -->
                    <Button x:Name="PurchaseButton"
                            Content="购买 Pro — 即将开放"
                            Click="PurchaseButton_Click"
                            Style="{DynamicResource DefaultButton}"
                            Padding="16,8"
                            FontSize="13"
                            Margin="0,0,0,8"/>

                    <!-- 输入 License Key -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="已有 License Key？" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="点击激活"
                                Click="ActivateButton_Click"
                                Style="{DynamicResource LinkButton}"
                                FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
